#!/bin/sh

FAILED=0

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.css' '*.md' '*.json')

if [ -n "$STAGED_FILES" ]; then
  echo "▶ format..."
  echo "$STAGED_FILES" | xargs pnpm exec prettier --write --ignore-unknown || FAILED=1
  echo "$STAGED_FILES" | xargs git add
fi

if [ $FAILED -eq 0 ]; then
  echo "▶ type check..."
  pnpm ts-check || FAILED=1
fi

if [ $FAILED -eq 0 ]; then
  echo "▶ lint check..."
  pnpm lint || FAILED=1
fi

STAGED_MESSAGES=$(git diff --cached --name-only --diff-filter=ACMRD -- 'messages/**/*.json')

if [ $FAILED -eq 0 ] && [ -n "$STAGED_MESSAGES" ]; then
  echo "▶ i18n check..."
  pnpm i18n:check --strict || FAILED=1
fi

if [ $FAILED -ne 0 ]; then
  echo ""
  echo "✗ Commit blocked: fix format, type errors or lint errors above."
  exit 1
fi
