# ─────────────────────────────────────────────────────────────────────────────
# Ovation Web — Environment variables
#
# Legend (annotation right after each key name):
#   [required]        — must be set. App will not function without it.
#   [prod]            — has a dev-safe default; MUST be overridden in production.
#   [optional]        — safe to leave empty; feature simply disables itself.
#   [feature:<name>]  — only required if that feature/integration is used.
#
# NEXT_PUBLIC_* values are inlined into the client bundle — never put secrets
# in a NEXT_PUBLIC_* variable.
#
# Source of truth: src/lib/utils/env.server.ts, src/lib/utils/env.client.ts.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                                       # [prod] production | development

# ── Public URLs (client + server) ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000                  # [prod] canonical site URL
NEXT_PUBLIC_API_URL=http://localhost:3001                  # [prod] ovation-api public URL
INTERNAL_API_URL=                                          # [optional] private/VPC URL used for server-to-server calls; falls back to NEXT_PUBLIC_API_URL
NEXT_PUBLIC_MEDIA_DOMAIN=                                  # [prod] CDN in front of the R2 bucket (e.g. media.ovationday.com)
OBJECT_STORAGE_PUBLIC_DOMAIN=                              # [optional] alias for NEXT_PUBLIC_MEDIA_DOMAIN used by SEO helpers

# ── i18n ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALLOWED_LOCALIZATION=en,es,pt,it,de,id,ms,tr,nl,no,th,da,fi,ko,pl,ro,hu,lt,lv,et,el,sk,sl,hr,cs,vi,uk,sv,fr,fil  # [required] comma-separated locale codes; first is default
DEFAULT_LOCALE=en                                          # [optional]

# ── Legal entity (rendered in Privacy Notice / Terms) ────────────────────────
NEXT_PUBLIC_LEGAL_ENTITY_NAME=                             # [prod] e.g. "Ovation LLC"
NEXT_PUBLIC_LEGAL_ENTITY_ADDRESS=                          # [prod] full postal address
NEXT_PUBLIC_EMAIL_DOMAIN=ovationday.com                    # [optional] used for support@, press@, etc.
NEXT_PUBLIC_HELP_URL=https://ovation.help                  # [optional]

# ── Database (better-auth adapter) ───────────────────────────────────────────
DATABASE_URL=                                              # [required] same Postgres as ovation-api

# ── Auth (better-auth) ───────────────────────────────────────────────────────
# Two independent 32+ byte secrets — MUST match the values in ovation-api.
AUTH_COOKIE_SECRET=                                        # [required] min 32 chars; shared with ovation-api
AUTH_HASH_PEPPER=                                          # [required] min 32 chars; shared with ovation-api
COOKIE_DOMAIN=                                             # [prod] e.g. ".ovationday.com" — leave unset in dev
TRUSTED_ORIGINS=http://localhost:3000                      # [prod] comma-separated
REQUIRE_EMAIL_VERIFICATION=false                           # [optional] set 'true' in production

# Shared secret used when the web calls the API for transactional emails.
INTERNAL_API_SECRET=                                       # [prod] must match ovation-api INTERNAL_API_SECRET

# ── OAuth providers ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                                          # [feature:google-oauth]
GOOGLE_CLIENT_SECRET=                                      # [feature:google-oauth]
APPLE_CLIENT_ID=                                           # [feature:apple-oauth]
APPLE_CLIENT_SECRET=                                       # [feature:apple-oauth]

# ── Payments (Paddle.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=                           # [feature:payments] public checkout token
NEXT_PUBLIC_PADDLE_ENV=sandbox                             # [prod] sandbox | production
NEXT_PUBLIC_PEECHO_BUTTON_URL=                             # [feature:print] Peecho button embed URL

# ── Anti-bot (Cloudflare Turnstile) ──────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=                            # [feature:turnstile]
TURNSTILE_SECRET_KEY=                                      # [feature:turnstile] server-side verification key

# ── Cloudflare origin protection ─────────────────────────────────────────────
CF_ORIGIN_TOKEN=                                           # [prod] must match ovation-api; leave unset before CF Transform Rule is live

# ── Coming-soon gate ─────────────────────────────────────────────────────────
COMING_SOON_ENABLED=                                       # [optional] 'true' to gate all routes
COMING_SOON_PASSWORD=                                      # [optional] required when COMING_SOON_ENABLED=true

# ── Blog revalidation ────────────────────────────────────────────────────────
# Shared secret checked by /api/revalidate-blog when ovation-api calls it after
# publishing an article. Empty disables the check (dev only).
BLOG_REVALIDATE_SECRET=                                    # [feature:blog] must match ovation-api BLOG_PUBLIC_REVALIDATE_SECRET

# ── Observability (server) ───────────────────────────────────────────────────
SENTRY_DSN=                                                # [optional] server-side error tracking; recommended in production

# ── Observability (client — NEXT_PUBLIC_*) ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=                                    # [optional] browser-side error tracking
NEXT_PUBLIC_SENTRY_ENV=                                    # [optional]
NEXT_PUBLIC_POSTHOG_KEY=                                   # [optional] product analytics (recommended)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com          # [optional]
NEXT_PUBLIC_POSTHOG_EXCLUDED_EMAILS=                       # [optional] comma-separated internal emails to exclude from analytics
NEXT_PUBLIC_GTM_ID=                                        # [optional] Google Tag Manager container id
NEXT_PUBLIC_COOKIEYES_ID=                                  # [optional] cookie-consent banner id

# ── SEO ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=                      # [optional] Google Search Console verification token
